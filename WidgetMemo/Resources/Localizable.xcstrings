    "All 4 boards' memo, settings, board names, and backups will all be reset. This cannot be undone." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيتم إعادة تعيين المذكرات والإعدادات وأسماء اللوحات والنسخ الاحتياطية لجميع اللوحات الأربع. لا يمكن التراجع عن هذا الإجراء."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notizen, Einstellungen, Board-Namen und Backups aller 4 Boards werden zurückgesetzt. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las notas, ajustes, nombres y copias de seguridad de los 4 tableros se restablecerán. Esta acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les mémos, réglages, noms et sauvegardes des 4 tableaux seront réinitialisés. Cette action est irréversible."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Memo, pengaturan, nama papan, dan cadangan dari semua 4 papan akan direset. Tindakan ini tidak dapat dibatalkan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le note, le impostazioni, i nomi e i backup di tutte le 4 bacheche verranno ripristinati. Questa azione non può essere annullata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "全 4 ボードのメモ内容・設定・ボード名・バックアップがすべて初期化されます。この操作は取り消せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "4개 보드의 메모, 설정, 보드 이름 및 백업이 모두 초기화됩니다. 이 작업은 되돌릴 수 없습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As notas, configurações, nomes e backups de todos os 4 quadros serão redefinidos. Esta ação não pode ser desfeita."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Заметки, настройки, названия и резервные копии всех 4 досок будут сброшены. Это действие нельзя отменить."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "บันทึก การตั้งค่า ชื่อบอร์ด และข้อมูลสำรองของทั้ง 4 บอร์ดจะถูกรีเซ็ตทั้งหมด การดำเนินการนี้ไม่สามารถย้อนกลับได้"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ghi chú, cài đặt, tên bảng và bản sao lưu của tất cả 4 bảng sẽ được đặt lại. Thao tác này không thể hoàn tác."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "全部 4 个面板的备忘录、设置、面板名称和备份将全部重置。此操作无法撤消。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "全部 4 個面板的備忘錄、設定、面板名稱和備份將全部重置。此操作無法復原。"
          }
        }
      }
    },

    "This board's memo, settings, board name, and backups will all be reset. This cannot be undone." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيتم إعادة تعيين المذكرة والإعدادات واسم اللوحة والنسخ الاحتياطية لهذه اللوحة. لا يمكن التراجع عن هذا الإجراء."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notiz, Einstellungen, Board-Name und Backups dieses Boards werden zurückgesetzt. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La nota, ajustes, nombre del tablero y copias de seguridad se restablecerán. Esta acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le mémo, les réglages, le nom et les sauvegardes de ce tableau seront réinitialisés. Cette action est irréversible."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Memo, pengaturan, nama papan, dan cadangan papan ini akan direset. Tindakan ini tidak dapat dibatalkan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La nota, le impostazioni, il nome della bacheca e i backup verranno ripristinati. Questa azione non può essere annullata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このボードのメモ内容・設定・ボード名・バックアップがすべて初期化されます。この操作は取り消せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 보드의 메모, 설정, 보드 이름 및 백업이 모두 초기화됩니다. 이 작업은 되돌릴 수 없습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A nota, configurações, nome do quadro e backups serão redefinidos. Esta ação não pode ser desfeita."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Заметка, настройки, название доски и резервные копии будут сброшены. Это действие нельзя отменить."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "บันทึก การตั้งค่า ชื่อบอร์ด และข้อมูลสำรองของบอร์ดนี้จะถูกรีเซ็ตทั้งหมด การดำเนินการนี้ไม่สามารถย้อนกลับได้"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ghi chú, cài đặt, tên bảng và bản sao lưu của bảng này sẽ được đặt lại. Thao tác này không thể hoàn tác."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此面板的备忘录、设置、面板名称和备份将全部重置。此操作无法撤消。"
          }
        },
        "zh-Hant" : {
